{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "AllowedOrigins": "https://your-production-frontend-domain.com",
    "ConnectionStrings": {
        "DefaultConnection": "Server=YOUR_RDS_HOST;Database=QuranSchoolDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;"
    },
    "Jwt": {
        "Key": "YOUR_STRONG_PROD_SECRET_KEY_AT_LEAST_32_CHARS_LONG",
        "Issuer": "QuranSchoolIssuer",
        "Audience": "QuranSchoolAudience",
        "DurationInMinutes": 1440
    },
    "Serilog": {
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/log-.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7
                }
            }
        ]
    }
}