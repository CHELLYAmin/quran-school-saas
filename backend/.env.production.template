# Backend Production Environment Variables

# Database Connection (AWS RDS)
# Format: Host=your-rds-endpoint;Database=quranschool;Username=postgres;Password=yourpassword
ConnectionStrings__DefaultConnection=Host=database-1.cluster-xxxxxx.us-east-1.rds.amazonaws.com;Database=quranschool;Username=admin;Password=YourSecurePassword

# Security
Jwt__Key=YourSuperSecretKeyAtLeast32Characters!
Jwt__Issuer=QuranSchool
Jwt__Audience=QuranSchoolApp

# Stripe (Optional)
Stripe__SecretKey=sk_live_...
Stripe__PublishableKey=pk_live_...
Stripe__WebhookSecret=whsec_...
